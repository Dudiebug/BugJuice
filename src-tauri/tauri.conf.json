{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BugJuice",
  "version": "0.1.0",
  "identifier": "com.dudiebug.bugjuice",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run build",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "BugJuice",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "DudieBug",
    "category": "Utility",
    "shortDescription": "Battery monitoring and analytics for Windows",
    "longDescription": "BugJuice is an open-source battery monitoring and analytics app for Windows. Real-time wattage, per-app power attribution, sleep drain analysis, battery health trending — all with plain-english context, no raw numbers without explanation.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  }
}
